EXPO_PUBLIC_X_CLIENT_ID=YOUR_X_CLIENT_ID
EXPO_PUBLIC_X_API_BASE_URL=https://api.x.com/2
EXPO_PUBLIC_X_AUTHORIZATION_ENDPOINT=https://twitter.com/i/oauth2/authorize
EXPO_PUBLIC_X_TOKEN_ENDPOINT=https://api.x.com/2/oauth2/token
EXPO_PUBLIC_X_REVOCATION_ENDPOINT=https://api.x.com/2/oauth2/revoke

# Option A: Explicit redirect URI (recommended for dev/prod split).
# Example (dev): https://auth.expo.io/@yourname/focusx-app
# Example (prod): focusx://oauth/callback
EXPO_PUBLIC_X_REDIRECT_URI=

# Option B: If EXPO_PUBLIC_X_REDIRECT_URI is empty, app builds one from scheme/path.
EXPO_PUBLIC_X_REDIRECT_SCHEME=focusx
EXPO_PUBLIC_X_CALLBACK_PATH=oauth/callback

# Optional: Enable following-based search source (experimental, access-level dependent).
EXPO_PUBLIC_X_FEATURE_FOLLOWING_SOURCE=false

# Search page size (10-100)
EXPO_PUBLIC_X_MAX_RESULTS=20

